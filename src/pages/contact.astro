---
import Base from '../layouts/Base.astro';

const EMAIL = 'contact@worldtvchannels.org';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact — World TV Channels',
  inLanguage: 'en',
};
---
<Base
  title="Contact — World TV Channels"
  description="Have a question, feedback, or want to report a broken channel? Get in touch."
  jsonLd={jsonLd}
>
  <article class="legal container">
    <h1>Contact</h1>
    <p class="updated">We usually reply within 1–3 business days.</p>

    <h2>Email</h2>
    <p>
      The fastest way to reach us is by email:
    </p>
    <p class="contact-email">
      <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
    </p>

    <h2>What to write to us about</h2>
    <ul>
      <li><strong>Broken channel</strong> — tell us its name and what you see (an error, a black screen, something else).</li>
      <li><strong>Missing channel</strong> — send the name and the stream URL if you know it. Additions are made through the open iptv-org project.</li>
      <li><strong>Bug on the site</strong> — your browser, device and a short description of what happened.</li>
      <li><strong>Feature suggestion</strong> — we’re always happy to hear ideas.</li>
      <li><strong>Data deletion request</strong> — although we don’t store data on a server, get in touch with any GDPR question.</li>
      <li><strong>Advertising / partnership</strong> — a short note about what you have in mind.</li>
    </ul>

    <h2>What we can’t do</h2>
    <ul>
      <li>We don’t control what channels broadcast. If a channel airs something you don’t like, please contact the channel directly.</li>
      <li>We’re not an authorised representative of any channel or broadcaster.</li>
      <li>We don’t provide programme schedules, recordings or technical support for individual broadcasters.</li>
    </ul>

    <h2>Response time</h2>
    <p>
      This is a spare-time project, so replies usually arrive within 1–3 business
      days. Thanks for your patience.
    </p>
  </article>
</Base>
