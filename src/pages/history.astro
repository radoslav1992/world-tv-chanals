---
import Base from '../layouts/Base.astro';
import ChannelPlayer from '../components/ChannelPlayer.astro';
---
<Base title="Watch history — World TV Channels" description="The TV channels you watched most recently. Jump back to a channel you saw earlier." noindex={true}>
  <section class="container page-head">
    <h1>Watch history</h1>
    <p class="page-sub">The channels you watched recently.</p>
  </section>

  <section class="container player-section">
    <ChannelPlayer mode="history" showSearch={true} />
  </section>
</Base>
