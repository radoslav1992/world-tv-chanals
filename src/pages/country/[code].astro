---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ChannelCard from '../../components/ChannelCard.astro';
import { getChannelsByCountry, type Channel } from '../../lib/iptv';
import { countryByCode, TOP_COUNTRIES } from '../../lib/seo-data';

export const prerender = false;

const SITE_URL = 'https://worldtvchannels.com';
const { code = '' } = Astro.params;
const cc = code.toUpperCase();

let channels: Channel[] = [];
try {
  channels = await getChannelsByCountry(cc);
} catch { /* graceful */ }

const def = countryByCode(cc);
const name = channels[0]?.country || def?.name || cc;
const flag = channels[0]?.flag || '';

if (!def && channels.length === 0) {
  Astro.response.status = 404;
}

Astro.response.headers.set(
  'Cache-Control',
  Astro.response.status === 404 ? 'public, max-age=30' : 'public, max-age=120, s-maxage=600',
);

const total = channels.length;
const shown = channels.slice(0, 60);
const related = TOP_COUNTRIES.filter((c) => c.code !== cc).slice(0, 10);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${name} TV channels`,
    description: `Watch live TV channels from ${name}, free in your browser.`,
    inLanguage: 'en',
    url: `${SITE_URL}/country/${code.toLowerCase()}`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
      { '@type': 'ListItem', position: 2, name: 'Countries', item: `${SITE_URL}/country` },
      { '@type': 'ListItem', position: 3, name: name },
    ],
  },
];
---
<Base
  title={`Watch ${name} TV Channels Live Online — Free | World TV Channels`}
  description={`Watch live TV channels from ${name} free in your browser${total ? ` — ${total} channels available` : ''}. News, sport, entertainment and more.`}
  jsonLd={jsonLd}
>
  <Breadcrumbs crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Countries', href: '/country' },
    { label: name },
  ]} />

  <section class="container landing">
    <div class="landing-head">
      <h1>{flag ? `${flag} ` : ''}Watch {name} TV channels live</h1>
      <p class="landing-intro">
        Stream live television from {name} — news, sport, entertainment and more — free in your browser.
        Browse the channels below or open the full list in the player.
      </p>
      <div class="hero-ctas" style="justify-content:flex-start;">
        <a class="cta" href={`/?country=${cc}`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Open {name} in the player
        </a>
      </div>
      {total > 0 && <p class="landing-count">{total.toLocaleString('en')} live channels from {name} available right now.</p>}
    </div>

    {shown.length > 0 ? (
      <div class="stations view-grid landing-grid">
        {shown.map((c) => <ChannelCard channel={c} />)}
      </div>
    ) : (
      <p class="empty">Channels are loading or temporarily unavailable. <a href={`/?country=${cc}`}>Open the player</a> to try again.</p>
    )}

    {total > shown.length && (
      <p style="text-align:center;margin-top:1.5rem;">
        <a class="cta cta-secondary" href={`/?country=${cc}`}>See all {total.toLocaleString('en')} channels from {name} →</a>
      </p>
    )}

    <div class="landing-related">
      <h2>Other countries</h2>
      <div class="facet-grid">
        {related.map((c) => (
          <a class="facet-card" href={`/country/${c.code.toLowerCase()}`}><span class="facet-name">{c.name}</span></a>
        ))}
      </div>
      <p style="margin-top:1.5rem;"><a class="link-arrow" href="/category">Browse channels by category →</a></p>
    </div>
  </section>
</Base>
