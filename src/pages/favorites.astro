---
import Base from '../layouts/Base.astro';
import ChannelPlayer from '../components/ChannelPlayer.astro';
---
<Base title="Favorite channels — World TV Channels" description="Quick access to your saved TV channels. Watch your favorite channels free online." noindex={true}>
  <section class="container page-head">
    <h1>Favorite channels</h1>
    <p class="page-sub">Your saved TV channels.</p>
  </section>

  <section class="container player-section">
    <ChannelPlayer mode="favorites" showSearch={true} />
  </section>
</Base>
