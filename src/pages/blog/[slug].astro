---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await post.render();

const SITE_URL = 'https://worldtvchannels.com';

const body = post.body || '';
const wordCount = body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date,
  ...(post.data.updated ? { dateModified: post.data.updated } : {}),
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'World TV Channels',
    logo: { '@type': 'ImageObject', url: `${SITE_URL}/logo.png` },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${SITE_URL}/blog/${post.slug}`,
  },
  image: `${SITE_URL}/logo.png`,
  wordCount,
  inLanguage: 'en',
  keywords: post.data.tags.join(', '),
};
---
<Base
  title={`${post.data.title} — World TV Channels`}
  description={post.data.description}
  ogType="article"
  jsonLd={jsonLd}
  publishedTime={post.data.date}
  articleAuthor={post.data.author}
  articleTags={post.data.tags}
>
  <Breadcrumbs crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Blog', href: '/blog' },
    { label: post.data.title },
  ]} />

  <article class="container legal blog-post">
    <h1>{post.data.title}</h1>
    <p class="updated">
      <time datetime={post.data.date}>
        {new Date(post.data.date).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
      {post.data.author && <span> · {post.data.author}</span>}
      <span> · {readingTime} min read</span>
    </p>

    <Content />

    <div class="blog-cta">
      <p>Want to watch these channels live?</p>
      <div class="hero-ctas">
        <a class="cta cta-secondary" href="/#player">Watch online</a>
        <a class="cta cta-secondary" href="/blog">All articles</a>
      </div>
    </div>
  </article>
</Base>
