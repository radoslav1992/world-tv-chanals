---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const SITE_URL = 'https://bulgariaradio.com';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date,
  ...(post.data.updated ? { dateModified: post.data.updated } : {}),
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Радио България',
    logo: { '@type': 'ImageObject', url: `${SITE_URL}/logo.png` },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${SITE_URL}/blog/${post.slug}`,
  },
  inLanguage: 'bg',
  keywords: post.data.tags.join(', '),
};
---
<Base
  title={`${post.data.title} — Радио България`}
  description={post.data.description}
  ogType="article"
  jsonLd={jsonLd}
  publishedTime={post.data.date}
  articleAuthor={post.data.author}
>
  <Breadcrumbs crumbs={[
    { label: 'Начало', href: '/' },
    { label: 'Блог', href: '/blog' },
    { label: post.data.title },
  ]} />

  <article class="container legal blog-post">
    <h1>{post.data.title}</h1>
    <p class="updated">
      <time datetime={post.data.date}>
        {new Date(post.data.date).toLocaleDateString('bg-BG', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
      {post.data.author && <span> · {post.data.author}</span>}
    </p>

    <Content />

    <div class="blog-cta">
      <p>Искате да чуете тези станции на живо?</p>
      <div class="hero-ctas">
        <a class="cta cta-secondary" href="/#player">Слушай онлайн</a>
        <a class="cta cta-secondary" href="/blog">Всички статии</a>
      </div>
    </div>
  </article>
</Base>
