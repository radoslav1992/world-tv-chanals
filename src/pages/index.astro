---
import Base from '../layouts/Base.astro';
import Feature from '../components/Feature.astro';
import ChannelPlayer from '../components/ChannelPlayer.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, TOP_COUNTRIES } from '../lib/seo-data';

const topCategories = CATEGORIES.slice(0, 10);
const topCountries = TOP_COUNTRIES.slice(0, 12);

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const features = [
  {
    title: 'Thousands of channels',
    description: 'Live TV channels from around the world in one place — news, sport, movies, music, kids, documentaries and more.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M8 3l4 4 4-4"/></svg>',
  },
  {
    title: 'Favorite channels',
    description: 'Save the channels you love with one tap and find them again in your own section. Quick access to what you watch most.',
    icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.3l-5.4 3.2 1.4-6.1L3 10.4l6.2-.5L12 4l2.8 5.9 6.2.5-5 4 1.4 6.1z"/></svg>',
  },
  {
    title: 'Watch history',
    description: 'See the channels you watched recently and jump back to them in a single tap. Never lose an interesting channel.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>',
  },
  {
    title: 'Free and simple',
    description: 'No registration, no subscription, no hidden fees. Open it, pick a channel, watch.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7"/></svg>',
  },
  {
    title: 'Filter by country & category',
    description: 'Narrow thousands of channels down to exactly what you want — filter by country or by category in a click.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5h18M6 12h12M10 19h4"/></svg>',
  },
  {
    title: 'Works in any browser',
    description: 'Plays straight in your browser on desktop and mobile — no app to install, no set-top box, no dish.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/></svg>',
  },
];

const faqs = [
  {
    q: 'Is it free?',
    a: 'Yes, completely free. There is no subscription, no trial period and no hidden fees — just open the site and start watching.',
  },
  {
    q: 'Where do the channels come from?',
    a: 'The catalogue is powered by iptv-org, an open, community-maintained collection of publicly available TV streams from around the world. The broadcasts themselves are delivered by the respective channels.',
  },
  {
    q: 'Do I need to create an account?',
    a: 'No. Just open the site and start watching. Your favorite channels and history are stored locally in your browser.',
  },
  {
    q: 'How much data does it use?',
    a: 'Live video typically uses a few hundred megabytes to a couple of gigabytes per hour, depending on the stream quality. Streaming adapts to your connection automatically. On Wi-Fi you don’t use mobile data.',
  },
  {
    q: 'Why do some channels not play?',
    a: 'Live streams are maintained by broadcasters and the open-source community, so they occasionally change or go offline. Browsers also block streams that aren’t served over a secure (HTTPS) connection. If a channel won’t load, simply try another one.',
  },
  {
    q: 'Does it work outside my country?',
    a: 'Yes — it works anywhere with an internet connection. Some individual streams may be geo-restricted by their broadcaster, but the vast majority are available worldwide.',
  },
  {
    q: 'What technology is used to play the channels?',
    a: 'Channels are delivered using HLS (HTTP Live Streaming) and played with the open-source hls.js library, falling back to native playback on Safari and iOS. Everything runs in your browser.',
  },
  {
    q: 'Is it available on iOS / Android?',
    a: 'There is no separate mobile app — the website works in any modern mobile browser, including Safari on iOS and Chrome on Android.',
  },
  {
    q: 'How do I add a channel that’s missing?',
    a: 'The catalogue comes from the open iptv-org project. You can suggest a new channel or stream directly on the iptv-org GitHub repository, where the community reviews additions.',
  },
  {
    q: 'Is it safe for children?',
    a: 'Adult (NSFW) channels are filtered out of the catalogue. That said, live TV content is not controlled by us, so we recommend parental supervision for younger viewers.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'World TV Channels',
    browserRequirements: 'Requires a modern browser with HTML5 video support',
    applicationCategory: 'MultimediaApplication',
    description: 'Free web player for thousands of live TV channels from around the world.',
    inLanguage: 'en',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'World TV Channels',
    url: 'https://worldtvchannels.com',
    inLanguage: 'en',
    potentialAction: {
      '@type': 'SearchAction',
      target: 'https://worldtvchannels.com/#player',
      'query-input': 'required name=search_term_string',
    },
  },
];
---
<Base
  title="World TV Channels — Watch live TV from around the world, free"
  description="Watch thousands of live TV channels from around the world for free — news, sport, movies, music and more. Straight in your browser, no sign-up."
  jsonLd={jsonLd}
>
  <section class="hero container">
    <img class="hero-logo" src="/logo.png" alt="World TV Channels logo" width="160" height="160" />
    <h1>World TV Channels</h1>
    <p class="tagline">
      Watch thousands of live TV channels from around the world — news, sport, movies, music and more.
      Free, straight in your browser, no sign-up.
    </p>
    <div class="hero-ctas">
      <a class="cta" href="#player">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Start watching
      </a>
      <a class="cta cta-secondary" href="/channels">Browse channel guide</a>
    </div>
    <ul class="trust-row" aria-label="Quick facts">
      <li><strong>1000s</strong> of channels</li>
      <li><strong>Free</strong> no subscription</li>
      <li><strong>No</strong> sign-up</li>
    </ul>
  </section>

  <section id="player" class="container player-section">
    <div class="section-head">
      <h2>Watch live</h2>
      <p>Live TV channels from around the world, straight in your browser — no install, no sign-up.</p>
    </div>
    <ChannelPlayer />
  </section>

  <section id="features" class="container">
    <div class="section-head">
      <h2>Why World TV Channels</h2>
      <p>Everything you need to watch global TV — without the clutter.</p>
    </div>
    <div class="features features-six">
      {features.map((f) => <Feature title={f.title} description={f.description} icon={f.icon} />)}
    </div>
  </section>

  <section class="container">
    <div class="section-head">
      <h2>Explore the world’s TV</h2>
      <p>Jump straight to a category or country — or watch four channels at once.</p>
    </div>

    <div class="explore-callout">
      <div class="explore-callout-text">
        <h3>Multi-channel mosaic</h3>
        <p>Watch up to four live channels at the same time — perfect for breaking news, elections and live sport.</p>
      </div>
      <a class="cta" href="/mosaic">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Open multi-view
      </a>
    </div>

    <h3 class="explore-subhead">Popular categories</h3>
    <div class="genre-filters">
      {topCategories.map((c) => (
        <a class="genre-pill" href={`/category/${c.slug}`}>{c.name}</a>
      ))}
      <a class="genre-pill" href="/category">All categories →</a>
    </div>

    <h3 class="explore-subhead">Popular countries</h3>
    <div class="genre-filters">
      {topCountries.map((c) => (
        <a class="genre-pill" href={`/country/${c.code.toLowerCase()}`}>{c.name}</a>
      ))}
      <a class="genre-pill" href="/country">All countries →</a>
    </div>
  </section>

  <section class="container about-strip">
    <div class="section-head">
      <h2>About the project</h2>
    </div>
    <div class="prose">
      <p>
        World TV Channels is a small independent project with one goal: to make the world’s television
        easy to watch — on any device, anywhere. It’s built by people who love TV and isn’t affiliated
        with any particular broadcaster or media group.
      </p>
      <p>
        The catalogue is powered by <a href="https://github.com/iptv-org/iptv" target="_blank" rel="noopener noreferrer">iptv-org</a>
        — an open, community-maintained collection of publicly available streams. The broadcasts
        themselves (programmes, news, ads) belong to the respective channels.
      </p>
      <p><a class="link-arrow" href="/about">Read more about the project →</a></p>
    </div>
  </section>

  <section class="container">
    <div class="section-head">
      <h2>From the blog</h2>
      <p>Articles about international TV channels, broadcasting and streaming.</p>
    </div>
    <div class="blog-grid blog-grid-home">
      {latestPosts.map((post) => (
        <a href={`/blog/${post.slug}`} class="blog-card">
          <div class="blog-card-body">
            <div class="blog-card-tags">
              {post.data.tags.map((tag) => (
                <span class="tag-chip">{tag}</span>
              ))}
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
    <div style="text-align:center; margin-top:1.5rem;">
      <a class="link-arrow" href="/blog">All articles →</a>
    </div>
  </section>

  <section id="faq" class="container">
    <div class="section-head">
      <h2>Frequently asked questions</h2>
      <p>Short answers to the most common questions about the app.</p>
    </div>
    <div class="faq">
      {faqs.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="container cta-section">
    <h2>Ready to watch?</h2>
    <p>Pick a channel and start watching straight in your browser — free and without sign-up.</p>
    <div class="hero-ctas">
      <a class="cta" href="#player">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Start watching
      </a>
      <a class="cta cta-secondary" href="/channels">Browse channel guide</a>
    </div>
  </section>
</Base>
