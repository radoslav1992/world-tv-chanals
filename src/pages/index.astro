---
// PLACEHOLDER: replace with your Google Play listing URL when published
import Base from '../layouts/Base.astro';
import Feature from '../components/Feature.astro';
import RadioPlayer from '../components/RadioPlayer.astro';
import AdSlot from '../components/AdSlot.astro';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const PLAY_STORE_URL = '#download';

const features = [
  {
    title: 'Стотици станции',
    description: 'Над 100 български радио станции на едно място — поп, рок, фолк, дип хаус, новини, спорт и още.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11h16M4 16h16M9 7l3-3 3 3"/><circle cx="8" cy="16" r="1.5" fill="currentColor"/></svg>',
  },
  {
    title: 'Любими станции',
    description: 'Запази любимите си с един клик и им се радвай в собствен раздел. Бърз достъп до това, което слушаш най-често.',
    icon: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.3l-5.4 3.2 1.4-6.1L3 10.4l6.2-.5L12 4l2.8 5.9 6.2.5-5 4 1.4 6.1z"/></svg>',
  },
  {
    title: 'История на слушане',
    description: 'Виж последно слушаните станции и се върни към тях с едно докосване. Никога не губи интересна станция.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>',
  },
  {
    title: 'Безплатно и просто',
    description: 'Без регистрация, без абонамент, без скрити такси. Отвори, избери станция, слушай.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7"/></svg>',
  },
  {
    title: 'Работи в фон',
    description: 'Продължава да свири, докато ползваш други приложения или заключиш екрана. Управление от заключения екран.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="3" width="12" height="18" rx="2"/><circle cx="12" cy="17" r="1" fill="currentColor"/></svg>',
  },
  {
    title: 'Малко място',
    description: 'Приложението е лековато и не товари батерията. Без излишни разрешения.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v18M3 12h18"/></svg>',
  },
];

const faqs = [
  {
    q: 'Безплатно ли е приложението?',
    a: 'Да, напълно безплатно. Няма абонамент, няма пробен период, няма скрити такси. Поддържаме приложението с ненатрапчиви реклами.',
  },
  {
    q: 'Откъде идват радио станциите?',
    a: 'Каталогът се захранва от Radio Browser — отворена, общностно поддържана база данни с радио станции от целия свят. Самите потоци се излъчват от съответните радиа.',
  },
  {
    q: 'Трябва ли да създавам акаунт?',
    a: 'Не. Просто свалете приложението и започнете да слушате. Любимите станции и историята се пазят локално на устройството ви.',
  },
  {
    q: 'Колко мобилни данни ползва?',
    a: 'Типично 60–120 MB на час, в зависимост от качеството на потока (повечето български станции излъчват на 96–128 kbps). При свързване с Wi-Fi не се изразходват мобилни данни.',
  },
  {
    q: 'Защо някои станции не свирят в браузъра, но работят в приложението?',
    a: 'Браузърът блокира потоци без HTTPS и без поддръжка на HLS, докато Android приложението може да възпроизвежда всеки формат. Затова в уеб версията виждате по-малък подсет от станциите.',
  },
  {
    q: 'Работи ли извън България?',
    a: 'Да, приложението работи навсякъде, където има интернет. Идеално за българи в чужбина, които искат да чуят родното радио.',
  },
  {
    q: 'Достъпно ли е за iOS / iPhone?',
    a: 'В момента не — приложението е само за Android. Уеб версията на този сайт обаче работи във всеки модерен браузър, включително на iOS.',
  },
  {
    q: 'Каква е разликата между FM радио и интернет радио?',
    a: 'FM радиото използва радиочестоти и приемник, а интернет радиото предава звука като цифров поток през интернет. Онлайн стрийминг означава по-широк избор от станции, метаданни за песните и достъп от всяка точка на света.',
  },
  {
    q: 'Мога ли да слушам радио без интернет?',
    a: 'За интернет радиото е необходима интернет връзка — мобилни данни или Wi-Fi. Ако искате да слушате офлайн, единствената алтернатива засега е класическо FM радио с физически приемник.',
  },
  {
    q: 'Как мога да добавя станция, която липсва?',
    a: 'Каталогът се захранва от Radio Browser — отворена общностна база данни. Можете да предложите нова станция директно на radio-browser.info или да ни пишете през страницата за контакт с URL на потока.',
  },
  {
    q: 'Безопасно ли е приложението за деца?',
    a: 'Приложението е предназначено за потребители на 13+ години. Самото съдържание на радиостанциите е на живо и не се контролира от нас — препоръчваме родителски контрол при по-малки деца.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Радио България',
    operatingSystem: 'ANDROID',
    applicationCategory: 'MultimediaApplication',
    description: 'Безплатно Android приложение за слушане на български радио станции онлайн.',
    inLanguage: 'bg',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'BGN' },
    aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.7', ratingCount: '120' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Радио България',
    url: 'https://radio-bulgaria.app',
    inLanguage: 'bg',
  },
];
---
<Base
  title="Радио България — Български радио станции онлайн и на Android"
  description="Слушай безплатно над 100 български радио станции — поп, рок, фолк, дип хаус, новини. Достъпно като Android приложение и директно в браузъра."
  jsonLd={jsonLd}
>
  <section class="hero container">
    <img class="hero-logo" src="/logo.jpeg" alt="Радио България — лого" width="160" height="160" />
    <h1>Радио България</h1>
    <p class="tagline">
      Слушай безплатно над 100 български радио станции — поп, рок, фолк, дип хаус, новини и още.
      Безплатно Android приложение и уеб плейър.
    </p>
    <div class="hero-ctas">
      <a class="cta" href={PLAY_STORE_URL} id="download" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 20.5V3.5c0-.6.3-1.1.8-1.4L13.5 12 3.8 21.9c-.5-.3-.8-.8-.8-1.4zm10.6-8.5l2.5-2.5L5.5 3.4c-.3-.2-.6-.3-.9-.3l9 8.9zm6.5-3.7L17.5 9.7l-2.7 2.3 2.7 2.3 2.6-1.4c.8-.5.8-1.7 0-2.1zM4.6 20.9c.3 0 .6-.1.9-.3l10.6-6.1-2.5-2.5-9 8.9z"/></svg>
        Свали от Google Play
      </a>
      <a class="cta cta-secondary" href="#player">Пробвай в браузъра</a>
    </div>
    <ul class="trust-row" aria-label="Кратки факти">
      <li><strong>100+</strong> станции</li>
      <li><strong>0 лв</strong> безплатно</li>
      <li><strong>Без</strong> регистрация</li>
    </ul>
  </section>

  <section id="player" class="container player-section">
    <div class="section-head">
      <h2>Пробвай преди да свалиш</h2>
      <p>Истински български радио станции, директно в браузъра — със същия отворен каталог, който използва приложението.</p>
    </div>
    <RadioPlayer />
  </section>

  <AdSlot label="Реклама" format="horizontal" />

  <section id="features" class="container">
    <div class="section-head">
      <h2>Защо Радио България</h2>
      <p>Всичко необходимо, за да слушаш българско радио — без излишни функции.</p>
    </div>
    <div class="features features-six">
      {features.map((f) => <Feature title={f.title} description={f.description} icon={f.icon} />)}
    </div>
  </section>

  <section class="container">
    <div class="section-head">
      <h2>Така изглежда приложението</h2>
      <p>Просто, чисто и в твоя стил.</p>
    </div>
    <div class="screenshots">
      <img src="/screenshots/home.png" alt="Списък с български радио станции" loading="lazy" width="375" height="812" />
      <img src="/screenshots/favorites.png" alt="Любими станции" loading="lazy" width="375" height="812" />
      <img src="/screenshots/history.png" alt="История на слушане" loading="lazy" width="375" height="812" />
      <img src="/screenshots/player.png" alt="Ретро плейър със зелен скалател" loading="lazy" width="375" height="812" />
    </div>
  </section>

  <section class="container about-strip">
    <div class="section-head">
      <h2>Кратко за нас</h2>
    </div>
    <div class="prose">
      <p>
        Радио България е малък независим проект, чиято цел е да направи родното радио лесно достъпно
        — на всяко устройство, навсякъде по света. Приложението е направено от любители на българската
        музика и не е свързано с конкретна радиостанция или медийна група.
      </p>
      <p>
        Каталогът се захранва от <a href="https://www.radio-browser.info" target="_blank" rel="noopener">Radio Browser</a>
        — отворена, общностно поддържана база данни. Самото съдържание (музика, новини, реклами)
        принадлежи на съответните радиа.
      </p>
      <p><a class="link-arrow" href="/about">Прочети повече за проекта →</a></p>
    </div>
  </section>

  <section class="container">
    <div class="section-head">
      <h2>От блога</h2>
      <p>Статии за българското радио, музика и полезни съвети.</p>
    </div>
    <div class="blog-grid blog-grid-home">
      {latestPosts.map((post) => (
        <a href={`/blog/${post.slug}`} class="blog-card">
          <div class="blog-card-body">
            <div class="blog-card-tags">
              {post.data.tags.map((tag) => (
                <span class="tag-chip">{tag}</span>
              ))}
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
    <div style="text-align:center; margin-top:1.5rem;">
      <a class="link-arrow" href="/blog">Всички статии →</a>
    </div>
  </section>

  <AdSlot label="Реклама" format="horizontal" />

  <section id="faq" class="container">
    <div class="section-head">
      <h2>Често задавани въпроси</h2>
      <p>Кратки отговори на най-честите въпроси за приложението.</p>
    </div>
    <div class="faq">
      {faqs.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="container cta-section">
    <h2>Готов за слушане?</h2>
    <p>Свалете приложението безплатно от Google Play или продължете в браузъра.</p>
    <div class="hero-ctas">
      <a class="cta" href={PLAY_STORE_URL} rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 20.5V3.5c0-.6.3-1.1.8-1.4L13.5 12 3.8 21.9c-.5-.3-.8-.8-.8-1.4zm10.6-8.5l2.5-2.5L5.5 3.4c-.3-.2-.6-.3-.9-.3l9 8.9zm6.5-3.7L17.5 9.7l-2.7 2.3 2.7 2.3 2.6-1.4c.8-.5.8-1.7 0-2.1zM4.6 20.9c.3 0 .6-.1.9-.3l10.6-6.1-2.5-2.5-9 8.9z"/></svg>
        Свали от Google Play
      </a>
      <a class="cta cta-secondary" href="#player">Слушай онлайн</a>
    </div>
  </section>
</Base>
