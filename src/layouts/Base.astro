---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Path-relative or absolute image URL for Open Graph + Twitter. */
  ogImage?: string;
  /** Canonical path (defaults to current pathname). Useful to dedupe with/without trailing slash. */
  canonicalPath?: string;
  /** Page type for OpenGraph (default 'website'). */
  ogType?: 'website' | 'article';
  /** Optional JSON-LD structured-data object(s) to inject into <head>. */
  jsonLd?: object | object[];
  /** ISO date string for article:published_time (blog posts). */
  publishedTime?: string;
  /** Author name for article:author (blog posts). */
  articleAuthor?: string;
  /** Set true to add noindex (e.g. user-specific pages). */
  noindex?: boolean;
  /** OG article tags for blog posts. */
  articleTags?: string[];
}

const SITE_URL = 'https://worldtvchannels.org';
const SITE_NAME = 'World TV Channels';
const DEFAULT_DESC = 'Watch thousands of live TV channels from around the world for free — news, sport, movies, music and more. Straight in your browser, no sign-up.';

const {
  title,
  description = DEFAULT_DESC,
  ogImage = '/logo.png',
  canonicalPath,
  ogType = 'website',
  jsonLd,
  publishedTime,
  articleAuthor,
  noindex = false,
  articleTags = [],
} = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => (href === '/' ? path === '/' : path === href);

const canonical = new URL(canonicalPath ?? path, SITE_URL).toString();
const ogImageAbs = ogImage.startsWith('http') ? ogImage : new URL(ogImage, SITE_URL).toString();

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_NAME,
  url: SITE_URL,
  logo: `${SITE_URL}/logo.png`,
  sameAs: [],
};
const jsonLdArr = [orgJsonLd, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f1320" />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large'} />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:locale" content="en_US" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {articleAuthor && <meta property="article:author" content={articleAuthor} />}
    {articleTags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="alternate" type="application/rss+xml" title="World TV Channels — Blog" href="/rss.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {jsonLdArr.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}

    {/*
      AdSense — uncomment after approval and replace ca-pub-XXXXXXXXXXXXXXXX
      with your real publisher ID. The slots in the page templates will start
      filling automatically.

      <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
    */}

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-TT4LN8D2B8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-TT4LN8D2B8');
    </script>

    <title>{title}</title>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>

    <div class="flag-bar"><div class="w"></div><div class="g"></div><div class="r"></div></div>

    <header class="site">
      <div class="container row">
        <a class="brand" href="/">
          <img src="/logo.png" alt="" width="40" height="40" />
          <span class="brand-name">World TV Channels</span>
        </a>
        <button class="nav-toggle" type="button" aria-label="Menu" aria-expanded="false" aria-controls="main-nav">
          <span></span><span></span><span></span>
        </button>
        <nav class="site" id="main-nav">
          <a href="/" class:list={{ active: isActive('/') }}>Watch</a>
          <a href="/mosaic" class:list={{ active: path.startsWith('/mosaic') }}>Multi-view</a>
          <a href="/category" class:list={{ active: path.startsWith('/category') }}>Categories</a>
          <a href="/country" class:list={{ active: path.startsWith('/country') }}>Countries</a>
          <a href="/favorites" class:list={{ active: isActive('/favorites') }}>Favorites</a>
          <a href="/channels" class:list={{ active: path.startsWith('/channels') }}>Guide</a>
          <a href="/blog" class:list={{ active: path.startsWith('/blog') }}>Blog</a>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site">
      <div class="container footer-grid">
        <div class="footer-col footer-brand">
          <div class="brand">
            <img src="/logo.png" alt="" width="36" height="36" />
            <span>World TV Channels</span>
          </div>
          <p>Free access to thousands of live TV channels from around the world — straight in your browser.</p>
        </div>
        <div class="footer-col">
          <h4>Watch</h4>
          <a href="/">Watch online</a>
          <a href="/mosaic">Multi-view</a>
          <a href="/favorites">Favorites</a>
          <a href="/history">History</a>
        </div>
        <div class="footer-col">
          <h4>Explore</h4>
          <a href="/category">Categories</a>
          <a href="/country">Countries</a>
          <a href="/channels">Channel guide</a>
          <a href="/blog">Blog</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/sitemap-index.xml">Sitemap</a>
        </div>
        <div class="footer-col">
          <h4>Legal</h4>
          <a href="/privacy-policy">Privacy</a>
          <a href="/terms">Terms</a>
        </div>
      </div>
      <div class="container footer-bottom">
        <span>© 2026 World TV Channels. All rights reserved.</span>
        <span class="footer-credit">Channel data provided by <a href="https://github.com/iptv-org/iptv" target="_blank" rel="noopener noreferrer">iptv-org</a>.</span>
      </div>
    </footer>

    <div class="flag-bar bottom"><div class="w"></div><div class="g"></div><div class="r"></div></div>

    <!-- Cookie consent banner -->
    <div class="consent" data-consent hidden>
      <div class="consent-inner container">
        <div class="consent-text">
          <strong>This site uses cookies</strong>
          <p>
            We use only technically necessary storage to remember your choices
            (player, favorites, layout). Learn more in our
            <a href="/privacy-policy">Privacy Policy</a>.
          </p>
        </div>
        <div class="consent-actions">
          <button type="button" class="cta-secondary" data-consent-reject>Necessary only</button>
          <button type="button" class="cta" data-consent-accept>Accept</button>
        </div>
      </div>
    </div>

    <script>
      // Cookie consent: hide if a choice was already made; persist on click.
      (() => {
        const KEY = 'wtv-consent-v1';
        const banner = document.querySelector('[data-consent]') as HTMLElement | null;
        if (!banner) return;
        if (localStorage.getItem(KEY)) return;
        banner.hidden = false;
        const close = (value: 'accept' | 'reject') => {
          try { localStorage.setItem(KEY, value); } catch {}
          banner.hidden = true;
        };
        banner.querySelector('[data-consent-accept]')?.addEventListener('click', () => close('accept'));
        banner.querySelector('[data-consent-reject]')?.addEventListener('click', () => close('reject'));
      })();

      // Mobile nav toggle
      (() => {
        const btn = document.querySelector('.nav-toggle') as HTMLButtonElement | null;
        const nav = document.querySelector('#main-nav') as HTMLElement | null;
        if (!btn || !nav) return;
        btn.addEventListener('click', () => {
          const open = nav.classList.toggle('open');
          btn.setAttribute('aria-expanded', String(open));
        });
        nav.querySelectorAll('a').forEach((a) => {
          a.addEventListener('click', () => {
            nav.classList.remove('open');
            btn.setAttribute('aria-expanded', 'false');
          });
        });
      })();

      // Register service worker for PWA
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }
    </script>
  </body>
</html>
